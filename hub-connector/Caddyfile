{
    auto_https off
    admin off
}

# ── Port 8080: Hub API + gateway traffic ─────────────────────────────
# All requests are forwarded to the Cloud Run gateway with the shared
# connector API key. Hub-api traffic also gets X-Service: hub-api so
# the gateway routes it to the hub-api Cloud Run service.
# HUB_HOST = gateway hostname only (no scheme), e.g. demoforge-gateway-xxx.run.app
:8080 {
    # Health — proxy to gateway health (no auth required at gateway)
    handle /health {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }

    # All other hub traffic → gateway → hub-api
    handle {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            header_up X-Service hub-api
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }
}
