{
    auto_https off
    admin off
}

# ── Port 8080: Hub API + gateway traffic ─────────────────────────────
# All requests are forwarded to the Cloud Run gateway with the shared
# connector API key. Hub-api traffic also gets X-Service: hub-api so
# the gateway routes it to the hub-api Cloud Run service.
# HUB_HOST = gateway hostname only (no scheme), e.g. demoforge-gateway-xxx.run.app
:8080 {
    # Health — proxy to gateway health (no auth required at gateway)
    handle /health {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }

    # All other hub traffic → gateway → hub-api
    handle {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            header_up X-Service hub-api
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }
}

# ── Port 9000: MinIO S3 API ──────────────────────────────────────────
# FA machines point DEMOFORGE_SYNC_ENDPOINT at localhost:9000.
# The connector adds the API key + S3 service header so the gateway
# routes the request to MinIO. S3 SigV4 signatures are preserved
# (unsigned headers are not part of the canonical signed headers list).
:9000 {
    handle {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            header_up X-Service s3
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }
}

# ── Port 9001: MinIO Console ─────────────────────────────────────────
:9001 {
    handle {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            header_up X-Service console
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }
}

# ── Port 5000: Docker Registry ───────────────────────────────────────
# Docker client uses /v2/* paths; gateway routes /v2/* to VM registry.
:5000 {
    handle {
        reverse_proxy {env.HUB_HOST}:443 {
            header_up Host {env.HUB_HOST}
            header_up X-Api-Key {env.API_KEY}
            transport http {
                tls
                tls_server_name {env.HUB_HOST}
            }
        }
    }
}
