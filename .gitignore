# Dependencies
node_modules/

# Build output
frontend/dist/

# Environment
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Logs
*.log

# OMC state
.omc/

# Claude local settings
.claude/settings.local.json

# Generated data (compose files, rendered templates)
data/

# Screenshots and Playwright artifacts
.artifacts/
.playwright-mcp/

# Test artifacts
test-upload.txt

# License keys (sensitive)
data/licenses.yaml
!data/.gitkeep

# Large binary JARs (built via Docker)
*.jar

# User-created demo definitions (not templates)
demos/*.yaml
!demos/.gitkeep

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Backend extracted source (volume-mounted, not built from this repo)
backend/app/__pycache__/
backend_src/

# Validation artifacts
screenshots/
validation-report.html
validate_templates.py
precache-images.sh
