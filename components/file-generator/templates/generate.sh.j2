#!/bin/sh
# Auto-generated by DemoForge for node {{ node.id }}
# Multi-target Data Generator — writes to all connected clusters in parallel
# Control: touch /tmp/gen.stop to gracefully stop

{%- set target_edges = [] %}
{%- for edge in edges %}
{%- if edge.source == node.id and edge.connection_type == 'file-push' %}
{%- set target_node = nodes | selectattr('id', 'equalto', edge.target) | first %}
{%- if target_node %}{% set _ = target_edges.append({'edge': edge, 'target': target_node}) %}{% endif %}
{%- endif %}
{%- endfor %}

{%- if not target_edges %}
echo "No file-push connections configured."
echo "Connect this Data Generator to a MinIO node to set a target."
exit 0
{%- endif %}

# Remove old stop signal, write PID
rm -f /tmp/gen.stop
echo $$ > /tmp/gen.pid
mkdir -p /tmp/gen
trap 'echo "Generator stopped."; rm -f /tmp/gen.pid; exit 0' TERM INT

VARIANT="{{ node.variant or 'burst' }}"

echo "=== DemoForge Data Generator ==="
echo "Mode: $VARIANT | Targets: {{ target_edges | length }}"
echo "================================"

# ---- Set up mc aliases for all targets ----
{%- for item in target_edges %}
{%- set alias = 'target' ~ loop.index %}
{%- set port = 80 if (item.target.id.endswith('-lb') or item.target.component == 'nginx') else 9000 %}
{%- set endpoint = 'http://' ~ project_name ~ '-' ~ item.target.id ~ ':' ~ port %}
{%- set bucket = item.edge.connection_config.get('target_bucket', 'demo-bucket') if item.edge.connection_config else 'demo-bucket' %}
# Retry alias set until endpoint accepts the credentials (up to 120s)
echo "Configuring {{ alias }} -> {{ endpoint }}..."
_wait=0
until mc alias set {{ alias }} "{{ endpoint }}" "$FG_TARGET_ACCESS_KEY" "$FG_TARGET_SECRET_KEY" 2>/dev/null && mc ls {{ alias }} >/dev/null 2>&1; do
  if [ $_wait -ge 120 ]; then echo "Timeout waiting for {{ alias }} — continuing anyway"; mc alias set {{ alias }} "{{ endpoint }}" "$FG_TARGET_ACCESS_KEY" "$FG_TARGET_SECRET_KEY" 2>/dev/null; break; fi
  sleep 5; _wait=$((_wait+5))
done
mc mb "{{ alias }}/{{ bucket }}" --ignore-existing 2>/dev/null || true
echo "Target {{ loop.index }}: {{ alias }} -> {{ endpoint }} / {{ bucket }}"
{%- endfor %}

# ---- Per-target generate functions ----
{%- for item in target_edges %}
{%- set alias = 'target' ~ loop.index %}
{%- set bucket = item.edge.connection_config.get('target_bucket', 'demo-bucket') if item.edge.connection_config else 'demo-bucket' %}
{%- set file_count = item.edge.connection_config.get('file_count', '10') if item.edge.connection_config else '10' %}
{%- set file_size = item.edge.connection_config.get('file_size', '10KB') if item.edge.connection_config else '10KB' %}
{%- set file_format = item.edge.connection_config.get('file_format', 'random') if item.edge.connection_config else 'random' %}
{%- set rate = item.edge.connection_config.get('rate', '10') if item.edge.connection_config else '10' %}
{%- set edge_id = item.edge.connection_config.get('_original_edge_id', item.edge.id) if item.edge.connection_config else item.edge.id %}

generate_{{ alias }}() {
  local BATCH=1
  local ALIAS="{{ alias }}"
  local BUCKET="{{ bucket }}"
  local FILE_COUNT={{ file_count }}
  local FILE_SIZE="{{ file_size }}"
  local FILE_FORMAT="{{ file_format }}"
  local RATE={{ rate }}
  local EDGE_ID="{{ edge_id }}"
  local EXIT_CODE=0

  while true; do
    [ -f /tmp/gen.stop ] && break
    local i=1
    while [ $i -le $FILE_COUNT ]; do
      [ -f /tmp/gen.stop ] && EXIT_CODE=1 && break 2
      FILENAME="file-$(date +%s%N)-${ALIAS}-${BATCH}-${i}"
      case "$FILE_FORMAT" in
        csv)
          { echo "id,timestamp,value,category"
            j=1; while [ $j -le 100 ]; do echo "$j,$(date -u +%Y-%m-%dT%H:%M:%S),$((RANDOM % 10000)),cat-$((RANDOM % 5 + 1))"; j=$((j+1)); done
          } > /tmp/gen/${FILENAME}.csv
          mc cp /tmp/gen/${FILENAME}.csv "${ALIAS}/${BUCKET}/${FILENAME}.csv" 2>/dev/null || EXIT_CODE=1
          rm -f /tmp/gen/${FILENAME}.csv
          ;;
        json)
          echo "{\"id\":${i},\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%S)\",\"batch\":${BATCH}}" > /tmp/gen/${FILENAME}.json
          mc cp /tmp/gen/${FILENAME}.json "${ALIAS}/${BUCKET}/${FILENAME}.json" 2>/dev/null || EXIT_CODE=1
          rm -f /tmp/gen/${FILENAME}.json
          ;;
        *)
          dd if=/dev/urandom bs=${FILE_SIZE} count=1 of=/tmp/gen/${FILENAME}.bin 2>/dev/null
          mc cp /tmp/gen/${FILENAME}.bin "${ALIAS}/${BUCKET}/${FILENAME}.bin" 2>/dev/null || EXIT_CODE=1
          rm -f /tmp/gen/${FILENAME}.bin
          ;;
      esac
      [ "$RATE" -gt 0 ] 2>/dev/null && sleep 0.$(printf '%03d' $((1000 / RATE)))
      i=$((i+1))
    done
    echo "[${ALIAS}] Batch ${BATCH} done."
    BATCH=$((BATCH+1))
    [ "$VARIANT" != "steady" ] && break
    sleep 5
  done

  # Write per-target status to a temp file (read by instances polling)
  if [ $EXIT_CODE -eq 0 ]; then
    echo "applied" > /tmp/gen_status_{{ alias }}.txt
  else
    echo "failed" > /tmp/gen_status_{{ alias }}.txt
  fi
  return $EXIT_CODE
}
{%- endfor %}

# ---- Launch all targets in parallel ----
{%- for item in target_edges %}
{%- set alias = 'target' ~ loop.index %}
generate_{{ alias }} &
PID_{{ alias }}=$!
{%- endfor %}

# ---- Wait for each target and collect exit codes ----
{%- for item in target_edges %}
{%- set alias = 'target' ~ loop.index %}
wait $PID_{{ alias }}
STATUS_{{ alias }}=$?
{%- endfor %}

# ---- Write consolidated status JSON ----
printf '{' > /tmp/gen_status.json
{%- for item in target_edges %}
{%- set alias = 'target' ~ loop.index %}
{%- set edge_id = item.edge.id %}
printf '"{{ edge_id }}":"%s"{{ "," if not loop.last else "" }}' "$(cat /tmp/gen_status_{{ alias }}.txt 2>/dev/null || echo failed)" >> /tmp/gen_status.json
{%- endfor %}
printf '}' >> /tmp/gen_status.json

echo "Generator finished."
rm -f /tmp/gen.pid
