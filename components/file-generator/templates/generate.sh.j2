#!/bin/sh
# Auto-generated by DemoForge for node {{ node.id }}
# Data Generator — generates synthetic files and pushes to S3
set -e

{% set target_edges = [] %}
{% for edge in edges %}
{% if edge.source == node.id and edge.connection_type == 'file-push' %}
{% set target_node = nodes | selectattr('id', 'equalto', edge.target) | first %}
{% if target_node %}{% set _ = target_edges.append({'edge': edge, 'target': target_node}) %}{% endif %}
{% endif %}
{% endfor %}

{% if target_edges %}
{% for item in target_edges %}
# Target: {{ item.target.id }}
TARGET_ENDPOINT="http://{{ project_name }}-{{ item.target.id }}:9000"
TARGET_BUCKET="{{ item.edge.connection_config.get('target_bucket', 'demo-bucket') if item.edge.connection_config else 'demo-bucket' }}"
FILE_COUNT={{ item.edge.connection_config.get('file_count', '100') if item.edge.connection_config else '100' }}
FILE_SIZE="{{ item.edge.connection_config.get('file_size', '1MB') if item.edge.connection_config else '1MB' }}"
FILE_FORMAT="{{ item.edge.connection_config.get('file_format', 'random') if item.edge.connection_config else 'random' }}"
RATE={{ item.edge.connection_config.get('rate', '10') if item.edge.connection_config else '10' }}

echo "=== DemoForge Data Generator ==="
echo "Target:  $TARGET_ENDPOINT / $TARGET_BUCKET"
echo "Files:   $FILE_COUNT x $FILE_SIZE ($FILE_FORMAT)"
echo "Rate:    $RATE files/sec (0=burst)"
echo "================================"

# Set up mc alias
mc alias set target "$TARGET_ENDPOINT" "$FG_TARGET_ACCESS_KEY" "$FG_TARGET_SECRET_KEY"
mc mb "target/$TARGET_BUCKET" --ignore-existing

echo "Starting generation..."
for i in $(seq 1 $FILE_COUNT); do
  FILENAME="file-$(date +%s%N)-$i"

  case "$FILE_FORMAT" in
    csv)
      # Generate CSV with random data
      echo "id,timestamp,value,category" > /tmp/$FILENAME.csv
      for j in $(seq 1 100); do
        echo "$j,$(date -u +%Y-%m-%dT%H:%M:%S),$(shuf -i 1-10000 -n 1),cat-$(shuf -i 1-5 -n 1)" >> /tmp/$FILENAME.csv
      done
      mc cp /tmp/$FILENAME.csv "target/$TARGET_BUCKET/$FILENAME.csv"
      rm -f /tmp/$FILENAME.csv
      ;;
    json)
      # Generate JSON with random data
      echo "{\"id\":$i,\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%S)\",\"data\":\"$(head -c 100 /dev/urandom | base64 | head -c 100)\"}" | \
        mc pipe "target/$TARGET_BUCKET/$FILENAME.json"
      ;;
    *)
      # Random binary data
      dd if=/dev/urandom bs=$FILE_SIZE count=1 2>/dev/null | mc pipe "target/$TARGET_BUCKET/$FILENAME.bin"
      ;;
  esac

  if [ "$RATE" -gt 0 ] 2>/dev/null; then
    sleep $(awk "BEGIN{printf \"%.3f\", 1/$RATE}")
  fi

  printf "\r[$i/$FILE_COUNT] uploaded"
done

echo ""
echo "Done. $FILE_COUNT files uploaded to target/$TARGET_BUCKET"
{% endfor %}
{% else %}
echo "No file-push connections configured."
echo "Connect this Data Generator to a MinIO or NGINX node to set a target."
echo ""
echo "Manual usage:"
echo "  mc alias set target http://<endpoint>:9000 <access-key> <secret-key>"
echo "  dd if=/dev/urandom bs=1M count=1 | mc pipe target/demo-bucket/test.bin"
{% endif %}
