#!/bin/sh
# Auto-generated by DemoForge for node {{ node.id }}
# Data Generator — generates synthetic files and pushes to S3
# Supports one-shot (burst) and continuous (steady) modes
# Control: touch /tmp/gen.stop to gracefully stop

{%- set target_edges = [] %}
{%- for edge in edges %}
{%- if edge.source == node.id and edge.connection_type == 'file-push' %}
{%- set target_node = nodes | selectattr('id', 'equalto', edge.target) | first %}
{%- if target_node %}{% set _ = target_edges.append({'edge': edge, 'target': target_node}) %}{% endif %}
{%- endif %}
{%- endfor %}

{%- if target_edges %}
{%- for item in target_edges %}
# Target: {{ item.target.id }} ({{ item.target.component }})
{%- if item.target.component == 'nginx' %}
TARGET_ENDPOINT="http://{{ project_name }}-{{ item.target.id }}:80"
{%- else %}
TARGET_ENDPOINT="http://{{ project_name }}-{{ item.target.id }}:9000"
{%- endif %}
TARGET_BUCKET="{{ item.edge.connection_config.get('target_bucket', 'demo-bucket') if item.edge.connection_config else 'demo-bucket' }}"
FILE_COUNT={{ item.edge.connection_config.get('file_count', '100') if item.edge.connection_config else '100' }}
FILE_SIZE="{{ item.edge.connection_config.get('file_size', '1MB') if item.edge.connection_config else '1MB' }}"
FILE_FORMAT="{{ item.edge.connection_config.get('file_format', 'random') if item.edge.connection_config else 'random' }}"
RATE={{ item.edge.connection_config.get('rate', '10') if item.edge.connection_config else '10' }}
VARIANT="{{ node.variant or 'burst' }}"

# Remove stop signal
rm -f /tmp/gen.stop

# Write PID for stop control
echo $$ > /tmp/gen.pid

trap 'echo "Generator stopped."; rm -f /tmp/gen.pid; exit 0' TERM INT

echo "=== DemoForge Data Generator ==="
echo "Target:  $TARGET_ENDPOINT / $TARGET_BUCKET"
echo "Files:   $FILE_COUNT x $FILE_SIZE ($FILE_FORMAT)"
echo "Rate:    $RATE files/sec (0=burst)"
echo "Mode:    $VARIANT"
echo "================================"

# Set up mc alias
mc alias set target "$TARGET_ENDPOINT" "$FG_TARGET_ACCESS_KEY" "$FG_TARGET_SECRET_KEY"
mc mb "target/$TARGET_BUCKET" --ignore-existing

mkdir -p /tmp/gen

generate_batch() {
  local BATCH=$1
  echo "[Batch $BATCH] Starting $FILE_COUNT files..."
  for i in $(seq 1 $FILE_COUNT); do
    # Check for stop signal
    [ -f /tmp/gen.stop ] && echo "Stop signal received." && return 1

    FILENAME="file-$(date +%s%N)-${BATCH}-${i}"

    case "$FILE_FORMAT" in
      csv)
        echo "id,timestamp,value,category" > /tmp/gen/$FILENAME.csv
        for j in $(seq 1 100); do
          echo "$j,$(date -u +%Y-%m-%dT%H:%M:%S),$(shuf -i 1-10000 -n 1),cat-$(shuf -i 1-5 -n 1)" >> /tmp/gen/$FILENAME.csv
        done
        mc cp /tmp/gen/$FILENAME.csv "target/$TARGET_BUCKET/$FILENAME.csv" 2>/dev/null
        rm -f /tmp/gen/$FILENAME.csv
        ;;
      json)
        echo "{\"id\":$i,\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%S)\",\"data\":\"$(head -c 100 /dev/urandom | base64 | head -c 100)\"}" > /tmp/gen/$FILENAME.json
        mc cp /tmp/gen/$FILENAME.json "target/$TARGET_BUCKET/$FILENAME.json" 2>/dev/null
        rm -f /tmp/gen/$FILENAME.json
        ;;
      *)
        dd if=/dev/urandom bs=$FILE_SIZE count=1 of=/tmp/gen/$FILENAME.bin 2>/dev/null
        mc cp /tmp/gen/$FILENAME.bin "target/$TARGET_BUCKET/$FILENAME.bin" 2>/dev/null
        rm -f /tmp/gen/$FILENAME.bin
        ;;
    esac

    if [ "$RATE" -gt 0 ] 2>/dev/null; then
      if [ "$RATE" -ge 1 ] 2>/dev/null; then
        sleep 0.$(printf '%03d' $((1000 / RATE)))
      else
        sleep 1
      fi
    fi

    printf "\r[Batch $BATCH: $i/$FILE_COUNT] uploaded"
  done
  echo ""
  echo "[Batch $BATCH] Done. $FILE_COUNT files uploaded."
  return 0
}

BATCH=1
if [ "$VARIANT" = "steady" ]; then
  echo "Steady mode: will loop continuously until stopped"
  while true; do
    [ -f /tmp/gen.stop ] && break
    generate_batch $BATCH || break
    BATCH=$((BATCH + 1))
    echo "Pausing 5s before next batch..."
    sleep 5
  done
else
  generate_batch $BATCH
fi

echo "Generator finished."
rm -f /tmp/gen.pid
{%- endfor %}
{%- else %}
echo "No file-push connections configured."
echo "Connect this Data Generator to a MinIO or NGINX node to set a target."
{%- endif %}
