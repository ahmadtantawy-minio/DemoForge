# Auto-generated by DemoForge
{% set upstreams = [] %}
{% set ns = namespace(algo='') %}
{% for edge in edges %}
{% if edge.source == node.id and edge.connection_type in ['s3', 'http', 'load-balance'] %}
{% set target_node = nodes | selectattr('id', 'equalto', edge.target) | first %}
{% if target_node %}
{% if edge.connection_config and edge.connection_config.algorithm %}
{% set ns.algo = edge.connection_config.algorithm %}
{% endif %}
{% set port = edge.connection_config.backend_port|default('9000') if edge.connection_config else '9000' %}
{% set _ = upstreams.append({'node': target_node, 'port': port}) %}
{% endif %}
{% endif %}
{% endfor %}

# S3 API upstream (port 9000)
upstream backend_s3 {
{% if ns.algo == 'least-conn' %}
    least_conn;
{% elif ns.algo == 'ip-hash' %}
    ip_hash;
{% endif %}
{% for upstream in upstreams %}
    server {{ project_name }}-{{ upstream.node.id }}:{{ upstream.port }};
{% endfor %}
{% if not upstreams %}
    server 127.0.0.1:9000;  # placeholder
{% endif %}
}

# MinIO Console upstream (port 9001)
upstream backend_console {
{% if ns.algo == 'least-conn' %}
    least_conn;
{% elif ns.algo == 'ip-hash' %}
    ip_hash;
{% endif %}
{% for upstream in upstreams %}
    server {{ project_name }}-{{ upstream.node.id }}:9001;
{% endfor %}
{% if not upstreams %}
    server 127.0.0.1:9001;  # placeholder
{% endif %}
}

# S3 API on port 80
server {
    listen 80;

    # Ignore invalid headers from MinIO
    ignore_invalid_headers off;

    location / {
        proxy_pass http://backend_s3;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 300s;

        # Identify which backend node handled the request
        add_header X-Upstream-Server $upstream_addr always;

        # S3 compatibility
        proxy_buffering off;
        proxy_request_buffering off;
        client_max_body_size 5g;
    }

    location /nginx_status {
        stub_status on;
        access_log off;
    }
}

# MinIO Console on port 9001
server {
    listen 9001;

    # Ignore invalid headers from MinIO
    ignore_invalid_headers off;

    location / {
        proxy_pass http://backend_console;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 300s;

        # WebSocket support for MinIO Console
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
