# Auto-generated by DemoForge
{% set upstreams = [] %}
{% for edge in edges %}
{% if edge.source == node.id and edge.connection_type in ['s3', 'http', 'load-balance'] %}
{% set target_node = nodes | selectattr('id', 'equalto', edge.target) | first %}
{% if target_node %}
{% set _ = upstreams.append(target_node) %}
{% endif %}
{% endif %}
{% endfor %}

upstream backend_pool {
{% for upstream in upstreams %}
    server {{ project_name }}-{{ upstream.id }}:9000;
{% endfor %}
{% if not upstreams %}
    server 127.0.0.1:9000;  # placeholder
{% endif %}
}

server {
    listen 80;

    location / {
        proxy_pass http://backend_pool;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 300s;

        # S3 compatibility
        proxy_buffering off;
        proxy_request_buffering off;
        client_max_body_size 5g;
    }

    location /nginx_status {
        stub_status on;
        access_log off;
    }
}
