{# Auto-generated by DemoForge for node {{ node.id }}
   Endpoint + via_loadbalancer must match compose S3 resolution so the browser
   hits the cluster/nginx LB (port 80, X-Upstream-Server) not a single MinIO :9000. #}
{% set ns = namespace(targets=[]) %}
{% for edge in edges %}
{% if edge.connection_type in ['s3', 'load-balance'] and (edge.target == node.id or edge.source == node.id) %}
{% set peer_id = edge.source if edge.target == node.id else edge.target %}
{% set peer_node = nodes | selectattr('id', 'equalto', peer_id) | first | default(none) %}
{% set peer_cluster = demo.clusters | selectattr('id', 'equalto', peer_id) | first | default(none) %}
{% if peer_node or peer_cluster %}
{% set _ = ns.targets.append({'edge': edge, 'peer_id': peer_id, 'peer_node': peer_node, 'peer_cluster': peer_cluster}) %}
{% endif %}
{% endif %}
{% endfor %}
{
{% if ns.targets %}
{% set t = ns.targets[0] %}
{% set peer_id = t.peer_id %}
{% set peer_node = t.peer_node %}
{% set peer_cluster = t.peer_cluster %}
{# Resolve MinIO LB: cluster id on edge, or pool member node id → same service as compose (…-lb:80) #}
{% set lbs = namespace(cl=peer_cluster) %}
{% if not lbs.cl and peer_node and peer_node.component == 'minio' %}
{% for c in demo.clusters %}
{% if peer_id != c.id and peer_id.startswith(c.id + '-') %}
{% set lbs.cl = c %}
{% endif %}
{% endfor %}
{% endif %}
{% if peer_node and peer_node.component == 'nginx' %}
  "endpoint": "http://{{ project_name }}-{{ peer_node.id }}:80",
  "via_loadbalancer": true,
{% elif lbs.cl %}
  "endpoint": "http://{{ project_name }}-{{ lbs.cl.id }}-lb:80",
  "via_loadbalancer": true,
{% elif peer_node and peer_node.component == 'minio' %}
  "endpoint": "http://{{ project_name }}-{{ peer_id }}:9000",
  "via_loadbalancer": false,
{% else %}
  "endpoint": "",
  "via_loadbalancer": false,
{% endif %}
{% if lbs.cl %}
  "access_key": {{ (lbs.cl.credentials.get('root_user', 'minioadmin'))|tojson }},
  "secret_key": {{ (lbs.cl.credentials.get('root_password', 'minioadmin'))|tojson }},
{% elif peer_node and peer_node.component == 'minio' %}
  "access_key": {{ (peer_node.config.get('MINIO_ROOT_USER', 'minioadmin'))|tojson }},
  "secret_key": {{ (peer_node.config.get('MINIO_ROOT_PASSWORD', 'minioadmin'))|tojson }},
{% else %}
  "access_key": "minioadmin",
  "secret_key": "minioadmin",
{% endif %}
  "connection_type": "{{ t.edge.connection_type }}",
  "source_component": "{{ peer_node.component if peer_node else (lbs.cl.component if lbs.cl else '') }}"
{% else %}
  "endpoint": "",
  "via_loadbalancer": false,
  "access_key": "minioadmin",
  "secret_key": "minioadmin",
  "connection_type": "none",
  "source_component": ""
{% endif %}
}
