{# Auto-generated by DemoForge for node {{ node.id }} #}
{% set targets = [] %}
{% for edge in edges %}
{% if edge.target == node.id and edge.connection_type in ['s3', 'load-balance'] %}
{% set source_node = nodes | selectattr('id', 'equalto', edge.source) | first %}
{% if source_node %}{% set _ = targets.append({'edge': edge, 'source': source_node}) %}{% endif %}
{% endif %}
{% endfor %}
{
{% if targets %}
{% set item = targets[0] %}
{% if item.source.component == 'nginx' %}
  "endpoint": "http://{{ project_name }}-{{ item.source.id }}:80",
  "via_loadbalancer": true,
{% else %}
  "endpoint": "http://{{ project_name }}-{{ item.source.id }}:9000",
  "via_loadbalancer": false,
{% endif %}
  "access_key": "minioadmin",
  "secret_key": "minioadmin",
  "connection_type": "{{ item.edge.connection_type }}",
  "source_component": "{{ item.source.component }}"
{% else %}
  "endpoint": "",
  "via_loadbalancer": false,
  "access_key": "minioadmin",
  "secret_key": "minioadmin",
  "connection_type": "none",
  "source_component": ""
{% endif %}
}
