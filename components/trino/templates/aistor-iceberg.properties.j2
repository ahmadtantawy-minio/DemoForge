{%- set aistor_source = [] %}
{%- for edge in edges %}
{%- if edge.target == node.id and edge.connection_type == 's3' %}
{%- set source_node = nodes | selectattr('id', 'equalto', edge.source) | first %}
{%- if source_node and source_node.component is defined and source_node.component == 'minio-aistore' %}
{%- if aistor_source.append(source_node) %}{% endif %}
{%- endif %}
{%- endif %}
{%- endfor %}
{%- if aistor_source %}
connector.name=iceberg
iceberg.catalog.type=rest
iceberg.rest-catalog.uri=http://{{ project_name }}-{{ aistor_source[0].id }}:9000/_iceberg
iceberg.rest-catalog.warehouse=analytics
iceberg.rest-catalog.security=OAUTH2
iceberg.rest-catalog.vended-credentials-enabled=true
fs.native-s3.enabled=true
s3.endpoint=http://{{ project_name }}-{{ aistor_source[0].id }}:9000
s3.path-style-access=true
s3.aws-access-key=minioadmin
s3.aws-secret-key=minioadmin
s3.region=us-east-1
{%- else %}
connector.name=memory
{%- endif %}
